<file path="style.css">
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Poppins;
}

body{
background:#050b18;
color:white;
}

/* NAVBAR */

.navbar{
display:flex;
justify-content:space-between;
align-items:center;
padding:20px 80px;
background:#040c1d;
border-bottom:1px solid #162037;
}

.logo{
display:flex;
align-items:center;
gap:12px;
}

.logo-box{
width:40px;
height:40px;
border-radius:10px;
display:flex;
align-items:center;
justify-content:center;
background:linear-gradient(135deg,#5ddcff,#c77dff);
font-weight:600;
}

.logo h2{
font-size:16px;
}

.logo p{
font-size:11px;
color:#7b8aa8;
}

nav{
display:flex;
gap:40px;
}

nav a{
color:#cbd5f5;
text-decoration:none;
font-size:14px;
}

.nav-right{
display:flex;
align-items:center;
gap:20px;
}

.nav-right a{
text-decoration:none;
color:#cbd5f5;
}


/* LOGIN AREA */

.login-area{
display:flex;
justify-content:center;
align-items:center;
height:85vh;
}

.login-box{

width:380px;
background:#0c1429;
padding:40px;
border-radius:16px;
border:1px solid #1b2746;
}

.login-logo{
width:50px;
height:50px;
background:linear-gradient(135deg,#5ddcff,#c77dff);
display:flex;
align-items:center;
justify-content:center;
border-radius:12px;
margin:auto;
margin-bottom:15px;
}

.login-box h1{
text-align:center;
font-size:22px;
margin-bottom:5px;
}

.subtitle{
text-align:center;
font-size:13px;
color:#7b8aa8;
margin-bottom:25px;
}


/* INPUT */

.input-group{
margin-bottom:20px;
}

.input-group label{
font-size:13px;
color:#b0b8d4;
}

.input-icon{
display:flex;
align-items:center;
gap:10px;
background:#101a34;
border:1px solid #1b2746;
padding:10px;
border-radius:8px;
margin-top:5px;
}

.input-icon input{
background:none;
border:none;
outline:none;
color:white;
width:100%;
}


/* FORGOT */

.forgot{
font-size:12px;
color:#4bc0ff;
cursor:pointer;
display:block;
margin-bottom:15px;
text-align:right;
}


/* BUTTON */

.btn-login{

width:100%;
padding:12px;
border:none;
border-radius:8px;
color:white;
font-weight:500;

background:linear-gradient(90deg,#35d0ff,#c04bff);

display:flex;
align-items:center;
justify-content:center;
gap:8px;

cursor:pointer;
}


/* REGISTER */

.register{
text-align:center;
font-size:13px;
margin-top:18px;
color:#7b8aa8;
}

.register span{
color:#3ecbff;
cursor:pointer;
}


/* DIVIDER */

.divider{
text-align:center;
margin:25px 0;
font-size:12px;
color:#7b8aa8;
}


/* SOCIAL */

.social-login{
display:flex;
gap:10px;
}

.social-login button{

flex:1;
padding:10px;

background:#101a34;
border:1px solid #1b2746;

color:white;

border-radius:8px;

display:flex;
align-items:center;
justify-content:center;

gap:8px;

cursor:pointer;
}

/* CARRINHO */

.cart-container{
display:flex;
justify-content:center;
align-items:center;
height:70vh;
}

.cart-empty{
text-align:center;
}

.cart-icon{
font-size:50px;
margin-bottom:20px;
color:#7b8aa8;
}

.cart-empty h1{
font-size:22px;
margin-bottom:10px;
}

.cart-empty p{
font-size:14px;
color:#7b8aa8;
margin-bottom:25px;
}

.btn-cart{
padding:12px 25px;
border:none;
border-radius:10px;
color:white;
font-weight:500;
background:linear-gradient(90deg,#35d0ff,#c04bff);
cursor:pointer;
}


/* FOOTER */

.footer{
border-top:1px solid #162037;
padding:40px 80px;
background:#040c1d;
}

.footer-content{
display:flex;
justify-content:space-between;
flex-wrap:wrap;
gap:40px;
}

.footer-left{
max-width:300px;
}

.footer-desc{
font-size:13px;
color:#7b8aa8;
margin-top:10px;
}

.footer h3{
font-size:14px;
margin-bottom:10px;
}

.footer a{
display:block;
text-decoration:none;
color:#7b8aa8;
font-size:13px;
margin-bottom:6px;
}

.footer a:hover{
color:white;
}

.copyright{
text-align:center;
margin-top:30px;
font-size:12px;
color:#7b8aa8;
}

/* ABOUT */

.about{
padding:60px 80px;
}

.about-header{
text-align:center;
margin-bottom:40px;
}

.about-header h1{
font-size:32px;
margin-bottom:10px;
}

.about-header span{
background:linear-gradient(90deg,#35d0ff,#c04bff);
-webkit-background-clip:text;
-webkit-text-fill-color:transparent;
}

.about-header p{
color:#7b8aa8;
font-size:14px;
}


/* MISSÃO */

.mission{
background:linear-gradient(135deg,#0c1429,#162037);
padding:30px;
border-radius:14px;
border:1px solid #1b2746;
margin-bottom:40px;
}

.mission h2{
margin-bottom:10px;
}

.mission p{
color:#b0b8d4;
font-size:14px;
line-height:1.6;
}


/* CARDS */

.about-cards{
display:flex;
gap:20px;
flex-wrap:wrap;
}

.about-card{
flex:1;
min-width:220px;
background:#0c1429;
border:1px solid #1b2746;
border-radius:14px;
padding:25px;
text-align:center;
transition:0.3s;
}

.about-card:hover{
transform:translateY(-5px);
border-color:#2a3a6b;
}

.about-card .icon{
font-size:28px;
margin-bottom:15px;
color:#35d0ff;
}

.about-card h3{
margin-bottom:8px;
}

.about-card p{
font-size:13px;
color:#7b8aa8;
}
